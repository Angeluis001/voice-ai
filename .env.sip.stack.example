STACK_NAME=voice-ai-sip

# Carrier edge
TELAIR_AUTH_ID=replace-me
TELAIR_AUTH_PASSWORD=replace-me
TELAIR_SIP_DOMAIN=sip.telair.net.au
TELAIR_TRANSPORT=udp
TELAIR_LISTEN_PORT=5060
TELAIR_INBOUND_CALLER_ID_FORMAT=0NSN
TELAIR_DID_RANGE=0734952900-2999

# Local ports
HOST_SIP_PORT=5060
HOST_DRACHTIO_ADMIN_PORT=9022
HOST_FREESWITCH_ESL_PORT=8021
HOST_FREESWITCH_SIP_PORT=5080
HOST_FREESWITCH_DEVICE_SIP_PORT=5062
HOST_FREESWITCH_RTP_START=20000
HOST_FREESWITCH_RTP_END=20100

# Image selection
KAMAILIO_IMAGE=kamailio/kamailio-ci:5.4.7-alpine.debug
DRACHTIO_SERVER_IMAGE=drachtio/drachtio-server:latest
FREESWITCH_IMAGE=drachtio/drachtio-freeswitch-mrf:latest
NODE_IMAGE=node:20-alpine

# Shared app secrets - replace locally
DRACHTIO_SECRET=replace-me
FREESWITCH_ESL_PASSWORD=replace-me
VOICE_APP_WEBHOOK_SECRET=replace-me

# SIP and network
DRACHTIO_LOGLEVEL=info
DRACHTIO_SOFIA_LOGLEVEL=3
DRACHTIO_PUBLIC_CONTACT=sip:drachtio-server:5060;transport=udp,tcp
DRACHTIO_ADMIN_ADDRESS=0.0.0.0
DRACHTIO_ADMIN_TLS_PORT=
FREESWITCH_RTP_START=20000
FREESWITCH_RTP_END=20100
FREESWITCH_DEVICE_SIP_PORT=5062
FREESWITCH_EXTERNAL_IP=replace-with-public-ip
MICROSIP_EXTENSION=1000
MICROSIP_EXTENSION_PASSWORD=replace-me
VOICE_APP_PORT=3000
B2B_TARGET_URI=sip:9196@freeswitch:5080
